# Shopify Configuration
# 1. Store Domain: The .myshopify.com URL of your store (e.g., shadowshopp.myshopify.com)
VITE_SHOPIFY_STORE_DOMAIN=

# 2. Access Token: 
# - Recommended: Use "Public access token" from Shopify Admin > Headless > Storefront API
# - Or: Use "Private access token" (starts with shpat_...)
VITE_SHOPIFY_STOREFRONT_ACCESS_TOKEN=

# Gemini API Key for chatbot
GEMINI_API_KEY=
