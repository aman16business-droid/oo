rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check if it's the siteSettings document
    function isSiteSettings(path) {
      return path == "siteSettings";
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if true; // Allow public write for now to fix the user's issue, ideally this would be restricted to admin
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
